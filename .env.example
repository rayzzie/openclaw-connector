UAG_GATEWAY_BASE_URL=http://localhost:8080
UAG_AGENT_ID=agent_001
UAG_AGENT_SK=
UAG_PROTOCOL_VERSION=uag.agent.v1
UAG_CONNECT_RETRY_MIN_MS=1000
UAG_CONNECT_RETRY_MAX_MS=30000
UAG_HEARTBEAT_INTERVAL_SEC=20
UAG_ACK_DEADLINE_MS=3000
UAG_ACK_MAX_RETRIES=2
MOCK_MODE=happy
LOG_LEVEL=info

# ── screenshot mode (MOCK_MODE=screenshot) ────────────────────────────────────
# URL to capture and stream as visual.frame on every agent.request
MOCK_SCREENSHOT_URL=http://localhost:18789/chat?session=agent%3Amain%3Aopenai-user%3A5gphone-caller-75de59371e7790ad
# Path to Chrome/Chromium binary (auto-detected on macOS if left empty)
MOCK_CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# ms to wait after page load before capturing (default 500)
MOCK_SCREENSHOT_WAIT_MS=500
# JPEG quality 1-100 (default 75)
MOCK_SCREENSHOT_QUALITY=75
# If >0, keep refreshing and pushing new frames every N ms during a call (0=single shot)
MOCK_SCREENSHOT_REFRESH_MS=0
