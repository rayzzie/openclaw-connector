{
  "name": "openclaw-channel-uniagentgate",
  "version": "1.0.0",
  "type": "module",
  "description": "OpenClaw channel plugin — bridges to uniAgentGate (5G RCS + SIP video)",
  "main": "dist/index.js",
  "files": [
    "dist/**/*.js",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channels": [
      "uniagentgate"
    ],
    "channel": {
      "id": "uniagentgate",
      "label": "uniAgentGate",
      "selectionLabel": "uniAgentGate (RCS + SIP Video)",
      "blurb": "Bridge OpenClaw conversations to uniAgentGate channel runtimes.",
      "order": 60,
      "aliases": [
        "uniagentgate",
        "uag"
      ]
    },
    "install": {
      "localPath": ".",
      "defaultChoice": "local",
      "minHostVersion": ">=2026.4.1"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.1"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  }
}
